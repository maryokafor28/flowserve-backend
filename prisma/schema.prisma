generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String         @id @default(uuid())
  name        String
  email       String         @unique
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  transactionsSent     Transaction[] @relation("senderTransactions")
  transactionsReceived Transaction[] @relation("receiverTransactions")

  @@index([email]) // Fast email lookup
}

model Transaction {
  id          String              @id @default(uuid())
  amount      Decimal               @db.Decimal(10, 2) 
  description String?
  status      TransactionStatus   @default(PENDING)
  senderId    String
  receiverId  String
  createdAt   DateTime            @default(now())

  sender   User @relation("senderTransactions", fields: [senderId], references: [id])
  receiver User @relation("receiverTransactions", fields: [receiverId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([createdAt])
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}